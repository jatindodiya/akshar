# Copy this file to .env and change the values before deploying.

# Any long random string — used to sign login tokens (JWT).
JWT_SECRET=change-this-to-a-long-random-secret

# Port the backend server listens on.
PORT=4000

# Comma-separated list of frontend origins allowed to call this API.
# For local testing the default (*) is fine.
CORS_ORIGIN=*
